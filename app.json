{
  "expo": {
    "name": "VenDish App",
    "slug": "vendish-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Logo2.jpg",
    "scheme": "food",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Logo2.jpg",
        "backgroundImage": "./assets/images/Logo2.jpg",
        "monochromeImage": "./assets/images/Logo2.jpg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.erzhadqt.food",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "food"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/531beae2-5e19-471b-8598-ec0e32ea490c"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3603b841-72b8-4dff-99ba-72bab743d592"
      }
    },
    "owner": "erzhadqt"
  }
}
